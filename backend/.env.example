# 🛠️ CẤU HÌNH MÔI TRƯỜNG SERVER (PRODUCTION)
# Sao chép file này thành ".env" trên Server (VPS)
# Và thay đổi các thông tin thật vào đây để bảo mật

# Cổng chạy server (Nginx nên proxy về cổng này)
PORT=3001

# Khóa bí mật để mã hóa phiên đăng nhập (Hãy tạo 1 chuỗi ngẫu nhiên dài và lưu lại)
JWT_SECRET=THAY_BANG_KEY_BI_MAT_CUA_BAN

# Tài khoản và mật khẩu đăng nhập cho tài khoản Admin ĐẦU TIÊN
ADMIN_USERNAME=admin_x
ADMIN_PASSWORD=your_super_strong_password_123

# Chế độ chạy (bắt buộc phải là "production" để bật nén cache và security headers)
NODE_ENV=production

# ─── RẤT QUAN TRỌNG: URL gốc của website (luôn dùng https trên production) ───
# Hostinger chạy Node qua Nginx proxy nên req.protocol = "http" thay vì "https"
# APP_URL giúp OAuth redirect URI luôn đúng dù chạy sau proxy
APP_URL=https://tientranstudio.com

# Google OAuth2 (Client Portal - đăng nhập bằng Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google Drive API Key (hiển thị ảnh từ Drive)
DRIVE_API_KEY=your_drive_api_key
