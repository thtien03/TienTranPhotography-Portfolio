# 🛠️ CẤU HÌNH MÔI TRƯỜNG SERVER (PRODUCTION)
# Sao chép file này thành ".env" trên Server (VPS)
# Và thay đổi các thông tin thật vào đây để bảo mật

# Cổng chạy server (Nginx nên proxy về cổng này)
PORT=3001

# Khóa bí mật để mã hóa phiên đăng nhập (Hãy tạo 1 chuỗi ngẫu nhiên dài và lưu lại)
# Ví dụ: mã hóa SHA256 hoặc Random Password Generator từ 32 ký tự trở lên
JWT_SECRET=THAY_BANG_KEY_BI_MAT_CUA_BAN

# Tài khoản và mật khẩu đăng nhập cho tài khoản Admin ĐẦU TIÊN
# Vì bản chất SQLite là file local, dùng thông tin này để khởi tạo account admin
ADMIN_USERNAME=admin_x
ADMIN_PASSWORD=your_super_strong_password_123

# Chế độ chạy (bắt buộc phải là "production" để bật nén cache và security headers)
NODE_ENV=production
